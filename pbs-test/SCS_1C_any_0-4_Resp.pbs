Script,StrongClubAny04Resp
window.currentPBSScenario = 'StrongClubAny04Resp';
window.currentPBSScenarioFilename = 'SCS_1C_any_0-4_Resp';
console.log('PBS: Logging scenario selection for StrongClubAny04Resp');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'StrongClubAny04Resp',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: Precision
convention-card-ew: 21GF-GIB
auction-filter: Auction.....\n1C
*/
produce 1000
dealer south

# South has 15+
hcp(south)>14

# North has 0-4
and hcp(north)<5
action printoneline,
`, "S", true)
Script
Button,Strong Club & 0-4 Resp,\n\
--- Strong Club with any 0-4 Response\n\
%StrongClubAny04Resp%,width=50% backgroundColor=lightpink
