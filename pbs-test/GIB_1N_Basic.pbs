Script,respToGibNt
window.currentPBSScenario = 'respToGibNt';
window.currentPBSScenarioFilename = 'GIB_1N_Basic';
console.log('PBS: Logging scenario selection for respToGibNt');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'respToGibNt',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: 21GF-GIB
convention-card-ew: 21GF-GIB
auction-filter: Auction.....\n1NT?
*/
# Basic Notrump responses
stayman = shape(south,any 54xx +any 4432 +any 4333 -5xxx-x5xx)
jacoby  = shape(south,6xxx +5xxx +x6xx +x5xx -any 66xx -any 65xx -any 55xx)
threeNT = shape(south,any 54xx +any 4432 +any 4333 -5xxx-x5xx)
pass    = hcp(south)<9 and not jacoby

gibNT and (pass or stayman or jacoby or threeNT) and hcp(south)<16

produce 30
action printoneline,

average pass 100 * pass,
average stayman 100 * stayman,
average jacoby 100 * jacoby,
average threeNT 100 * threeNT,
`, "N", true)
Script
Button,Resp to GIB NT,\n\
---  GIB Notrump Opening (North)\n\
GIB opens 1NT with 4333，4432， or 5332 w/15-17 HCP or 15-16 and a 5-card major\n\
and any 5422 without a 5-card major，without 4!S，and 15-16 HCP (too few points to reverse)\n\
Basic Responses includes Stayman，Jacoby Transfers，and Notrump Raises.\n\
%respToGibNt%
