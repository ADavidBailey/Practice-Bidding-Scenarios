Script,respToGibNt
window.currentPBSScenario = 'respToGibNt';
window.currentPBSScenarioFilename = 'GIB_1N_Basic';
console.log('PBS: Logging scenario selection for respToGibNt');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'respToGibNt',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: 21GF-GIB
convention-card-ew: 21GF-GIB
auction-filter: Auction.....\n1NT?
*/
##### Imported Script -- GIB 1 Notrump (North) #####

# GIB opens 1N w/15-17 HCP or 15-16 and a 5-card major
ntP = hcp(north) + shape(north,5xxx+x5xx)
nt1 = shape(north, any 5332+any 4432+any 4333) and hcp(north)>14 and ntP<18

# GIB does not open with 5422 and a 5-card major or with 4 spades
# GIB does not open with 5422 and the strength to reverse
nt2 = shape(north, any 5422-5xxx-x5xx-4xxx) and hcp(north)>14 and hcp(north)<17

gibNT = nt1 or nt2

### End of GIB 1 Notrump (North) ###
# defines gibNT

# Basic Notrump responses
stayman = shape(south,54xx+45xx+4xxx+x4xx) and hcp(south)>8
jacoby  = (spades(south)>4 or hearts(south)>4) and not stayman
threeNT = not (stayman or jacoby) and hcp(south)>9

gibNT and (stayman or jacoby or threeNT) and hcp(south)<16

produce 30
action printoneline,

average "stayman " 100 * stayman,
average "jacoby  " 100 * jacoby,
average "threeNT " 100 * threeNT,
`, "N", true)
Script
Button,Resp to GIB NT,\n\
---  GIB Notrump Opening (North)\n\
GIB opens 1NT with 4333，4432， or 5332 w/15-17 HCP or 15-16 and a 5-card major\n\
and any 5422 without a 5-card major，without 4!S，and 15-16 HCP (too few points to reverse)\n\
Basic Responses include Stayman，Jacoby Transfer，and 3 Notrump.\n\
%respToGibNt%
