Script,Serious
window.currentPBSScenario = 'Serious';
window.currentPBSScenarioFilename = 'Serious';
console.log('PBS: Logging scenario selection for Serious');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'Serious',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: 21GF-DEFAULT
convention-card-ew: 21GF-GIB
auction-filter: (1H +Pass +2N.*\n.*3H|1S +Pass +2N.*\n.*3S|1H +Pass +2[CDS].*\n.. +Pass +3H|1S +Pass +2[CDH].*\n.. +Pass +3S|1S +Pass +2H.*\n3H|1H +Pass +2S.*\n3S)
*/
/* That's a complex filter.  Here's a breakdown:
1M Pass 2N Pass, 3M by either
1M Pass 2/1, ... 3M by responder
1x Pass 2M Pass, 3M by either
*/


# Serious/Non-Serious
dealer north

# North's opening suit
NT = shape(north,any 4333+any 4432+any 5332-5xxx-x5xx) and hcp(north)>14 and hcp(north)<18
sN = spades(north)
hN = hearts(north)
dN = diamonds(north)
cN = clubs(north)
nS = sN>4 and sN>=hN and sN>=dN and sN>=cN     and spades(south)<4 and not NT
nH = not nS and hN>4 and hN>=dN and hN>=cN     and hearts(south)<4 and not NT
nD = not nS and not nH and ((dN>3 and dN>=cN)) and spades(north)<4 and hearts(north)<4 and not NT

# South's 2/1 responding suit
s = spades(south)
h = hearts(south)
d = diamonds(south)
c = clubs(south)
sS = s>=h and s>=d and s>=c
sH = not sS and h>=d and h>=c
sD = not sS and not sH and d>=c
sC = not sS and not sH and not sD

# North has 3+card support for South's responding suit
rC = sC and clubs(north)>2
rD = sD and diamonds(north)>2
rH = sH and hearts(north)>2

# South has 3+card support for North's opening suit
oS = nS and s>2
oH = nH and h>2
oD = nD and d>2

# (North supports South) or (South supports North)
fit = (rC or rD or rH) or (oS or oH or oD)

# North opens and South responds 2/1
nOpens = ((oS and (rC or rD or rH)) or (oH and (rC or rD)) or (nD and rC)) and fit and hcp(north)>11 and hcp(south)>12

# Avoid 3N-Choice-of-Games
sNT = shape(south,any 4333 +any 4432 +any 5332) and hcp(south,diamonds)>2 and hcp(south,clubs)>2

//sFit = spades(north) + spades(south) > 7
//hFit = hearts(north) + hearts(south) > 7
//majorFit = (sFit or hFit) and not sNT 

totalHCP = hcp(north) + hcp(south)
game = totalHCP>23 and totalHCP<32
slam = totalHCP>31 and totalHCP<36
grand = totalHCP>35

### Imported Leveling Code ###
c1 = hascard(west,2C)
c2 = hascard(east,2D)
c3 = hascard(west,3C)
c4 = hascard(east,3D)

keep06 = c1 and c2          // this is used later w/c3 & c4 expressions
keep44 = c3 or c4           // this is used later w/c1 & c2 expressions

keep015 = keep06 and c3
keep03 = keep06 and keep44
keep045 = keep06 and not c3
####06 = c1 and c2
keep11 = c1 and keep44
keep14 = c1 and not keep44
keep19 = c1 and not c2
keep25 = c1
keep30 = keep06 or c3
keep33 = c1 or (c2 and keep44)
####44 = c3 or c4
keep47 = keep44 or keep06

keep53 = not keep47
keep56 = not keep44
keep67 = not keep33
keep70 = not keep30
keep75 = not keep25
keep81 = not keep19
keep86 = not keep14
keep89 = not keep11
keep94 = not keep06
keep955 = not keep045
keep97 = not keep03
keep985 = not keep015
keep   = 1
keep0  = 0
### End of Imported Leveling Code ###

levGame  = game and keep03
levSlam  = slam and keep44
levGrand = grand and keep
levelTheDeal = levGame or levSlam or levGrand

# Now do it
nOpens and majorFit and (game or slam or grand) and hcp(north)<16
and levelTheDeal

action printoneline,
average "game " 100 * game,
average "slam " 100 * slam,
average "grand" 100 * grand,
`, "N", true)
Script
Button,Serious/Non-Serious,\n\
---  Serious/Non-Serious: When we're in a GF auction with a major suit fit and the bid\n\
is at 3 of our major，the step bid (or 3N) says I'm non-serious (or serious). It's a\n\
partnership agreement. Serious demands that partner cue-bid. I prefer non-serious as\n\
it avoids non-serious cue-bids which might reveal information，needlessly.\n\
The deal is leveled so that game and slam occur with about the same frequency.\n\
%Serious%
