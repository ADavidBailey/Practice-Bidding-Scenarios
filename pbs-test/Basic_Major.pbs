Script,BasicMajor
window.currentPBSScenario = 'BasicMajor';
window.currentPBSScenarioFilename = 'Basic_Major';
console.log('PBS: Logging scenario selection for BasicMajor');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'BasicMajor',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: Basic-Bridge
convention-card-ew: Basic-Bridge
auction-filter: Auction.....\n1[HS] +Pass +(1[SHN]|2N|[234][HS])
*/
# curate: kind=bidding
# convention-card-ns: Basic-Bridge
# convention-card-ew: Basic-Bridge


dealer south

# Opener — 1M with 5+ in the major, 12-21 HCP
sHcp    = hcp(south) > 11 and hcp(south) < 22
sMajor  = spades(south) > 4 or hearts(south) > 4
southHand = sHcp and sMajor

# Responder — 6-12 HCP for typical responses
nHcp    = hcp(north) > 5 and hcp(north) < 13
northHand = nHcp

# Quiet opponents
eHcp = hcp(east) < 11
wHcp = hcp(west) < 11

southHand and northHand and eHcp and wHcp

action printoneline,
average "South HCP avg "       hcp(south),
average "North HCP avg "       hcp(north),
average "S opens 1S    " 100 * (spades(south) > 4),
average "S opens 1H    " 100 * (hearts(south) > 4 and spades(south) < 5),
`, "S", true)
Script
Button,Basic 1M (Major),\n\
--- Basic 1M Opening (beginner)\n\
South opens 1!H or 1!S (12-21 HCP，5+ in that major).\n\
\n\
North's responses:\n\
• 1!S (over 1!H) — 6+ HCP，4+ spades，no fit\n\
• 1NT — 6+ HCP，no support，no 4-card major above opener's suit\n\
• Simple raise (2M) — 6-9 HCP with 3+ support\n\
• 2NT — 11-12 HCP balanced (in some systems this is Jacoby 2NT — see chart)\n\
• Limit raise (3M) — 10-12 HCP with 4+ support\n\
• Game raise (4M) — preemptive (0-7 HCP with 5+ support) or strong with 5+ trump\n\
\n\
For beginners: count HCP，count support cards，choose the right response.\n\
\n\
Reference: https://www.bridgebum.com/responses_to_one_of_a_major.php\n\
%BasicMajor%
