Script,PlayTopTricksNT
window.currentPBSScenario = 'PlayTopTricksNT';
window.currentPBSScenarioFilename = 'Play_Top_Tricks_NT';
console.log('PBS: Logging scenario selection for PlayTopTricksNT');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'PlayTopTricksNT',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: Basic-Bridge
convention-card-ew: Basic-Bridge
auction-filter: Auction.....\n1N +Pass +3N +Pass\nPass +Pass
*/
// ----- Opener (South) — 1NT, 15-17, Basic-Bridge balanced shape -----
sShape = shape(south, any 4333 + any 4432)
sHcp   = hcp(south) > 14 and hcp(south) < 18

// ----- Responder (North) — 9+ HCP, no 4-card major, no 5-card major
nNoMajor4 = spades(north) < 4 and hearts(north) < 4
nHcp = hcp(north) > 8

// ----- All 4 aces between the two hands -----
nsAllAces = (hascard(south, AS) or hascard(north, AS))
        and (hascard(south, AH) or hascard(north, AH))
        and (hascard(south, AD) or hascard(north, AD))
        and (hascard(south, AC) or hascard(north, AC))

// ----- Per-suit QT = consecutive top honors in the hand holding the Ace -----
// (chain stops when the next honor is in the OTHER hand or in opps)
//   0 = no A in NS    1 = A only    2 = AK    3 = AKQ    4 = AKQJ    5 = AKQJT
//
// We compute the chain separately for South and North; only one hand has
// the A in each suit, so adding the two values yields the suit's QT.

// Spades
sQtSp = hascard(south, AS) ? (hascard(south, KS) ? (hascard(south, QS) ? (hascard(south, JS) ? (hascard(south, TS) ? 5 : 4) : 3) : 2) : 1) : 0
nQtSp = hascard(north, AS) ? (hascard(north, KS) ? (hascard(north, QS) ? (hascard(north, JS) ? (hascard(north, TS) ? 5 : 4) : 3) : 2) : 1) : 0
qtSpades = sQtSp + nQtSp

// Hearts
sQtHr = hascard(south, AH) ? (hascard(south, KH) ? (hascard(south, QH) ? (hascard(south, JH) ? (hascard(south, TH) ? 5 : 4) : 3) : 2) : 1) : 0
nQtHr = hascard(north, AH) ? (hascard(north, KH) ? (hascard(north, QH) ? (hascard(north, JH) ? (hascard(north, TH) ? 5 : 4) : 3) : 2) : 1) : 0
qtHearts = sQtHr + nQtHr

// Diamonds
sQtDi = hascard(south, AD) ? (hascard(south, KD) ? (hascard(south, QD) ? (hascard(south, JD) ? (hascard(south, TD) ? 5 : 4) : 3) : 2) : 1) : 0
nQtDi = hascard(north, AD) ? (hascard(north, KD) ? (hascard(north, QD) ? (hascard(north, JD) ? (hascard(north, TD) ? 5 : 4) : 3) : 2) : 1) : 0
qtDiamonds = sQtDi + nQtDi

// Clubs
sQtCl = hascard(south, AC) ? (hascard(south, KC) ? (hascard(south, QC) ? (hascard(south, JC) ? (hascard(south, TC) ? 5 : 4) : 3) : 2) : 1) : 0
nQtCl = hascard(north, AC) ? (hascard(north, KC) ? (hascard(north, QC) ? (hascard(north, JC) ? (hascard(north, TC) ? 5 : 4) : 3) : 2) : 1) : 0
qtClubs = sQtCl + nQtCl

qtTotal = qtSpades + qtHearts + qtDiamonds + qtClubs

// Quiet opponents
eHcp = hcp(east) < 11
wHcp = hcp(west) < 11

sShape and sHcp and nNoMajor4 and nHcp and nsAllAces and qtTotal == 9 and eHcp and wHcp

action printoneline,
average "qt total (target=9) " qtTotal,
average "South HCP           " hcp(south),
average "North HCP           " hcp(north),
average "NS combined HCP     " hcp(south) + hcp(north),
`, "S", true)
Script
Button,Top Tricks (NT),\n\
--- Top Tricks — Notrump Contract (beginner)\n\
1NT — Pass — 3NT — all pass. Final contract is 3NT (declarer needs 9 tricks).\n\
\n\
Teaching feature: NS holds all 4 aces AND exactly 9 quick tricks on top.\n\
A quick trick counts only when the chain of top honors lives in the same\n\
hand as the Ace (split chains require an entry to extend，so they don't\n\
count as "quick"). 4 aces + 5 chain extensions = 9.\n\
\n\
Responder is constrained to no 4-card major (so no Stayman) and no 5-card\n\
major (so no transfer). The auction stays natural.\n\
\n\
Things to think about:\n\
• Count your top tricks before touching the hand.\n\
• AK in one hand = 2 QT; AK opposite Qx = also 2 QT (Q needs an entry).\n\
• If you have 9 top tricks，cash them; don't finesse for an overtrick.\n\
\n\
Reference: https://www.bridgebum.com/counting.php\n\
%PlayTopTricksNT%
