Script,PlayTopTricksNT
window.currentPBSScenario = 'PlayTopTricksNT';
window.currentPBSScenarioFilename = 'Play_Top_Tricks_NT';
console.log('PBS: Logging scenario selection for PlayTopTricksNT');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'PlayTopTricksNT',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: Basic-Bridge
convention-card-ew: Basic-Bridge
auction-filter: \[Deal .* .* .* .*\..*\..*\.*[789]
*/
# curate: kind=byforce
# convention-card-ns: Basic-Bridge
# convention-card-ew: Basic-Bridge


dealer south

// Predeal one ace to each hand to guarantee an entry to declarer and dummy
// and to slash the all-aces rejection rate (the dominant yield killer). The
// other two aces (HA, CA) are still required in NS by allSuitsStopped in
// script/topTricksNS, but roam between the hands for variety.
predeal south SA
predeal north DA

### Imported script: topTricksNS (NS combined Top Tricks)
//
// Per-suit topTricks = min(consecutive top-honor chain held by NS,
//                          longer single-hand length in that suit).
//
// Chain rules:
//   0 = no A in NS    1 = A only    2 = AK    3 = AKQ    4 = AKQJ    5 = AKQJT
//
// Cap rule:
//   Split chains require entries to materialize. We assume entries exist,
//   so AK opposite Qxx (longer hand = 3) counts as 3 top tricks, but AK
//   opposite Qx (longer hand = 2) counts only 2.
//
// Stopper rule:
//   In notrump, an unstopped suit (no A in NS for that suit) lets opps run
//   their length on the opening lead before declarer can cash any winners.
//   So if any suit lacks an A in NS, topTricksNS collapses to 0.
//
// Exports: topTricksSpades, topTricksHearts, topTricksDiamonds,
//          topTricksClubs, topTricksNS

// ---- Has-honor checks (either hand) ----
hasAceSpades   = hascard(south, AS) or hascard(north, AS)
hasKingSpades  = hascard(south, KS) or hascard(north, KS)
hasQueenSpades = hascard(south, QS) or hascard(north, QS)
hasJackSpades  = hascard(south, JS) or hascard(north, JS)
hasTenSpades   = hascard(south, TS) or hascard(north, TS)

hasAceHearts   = hascard(south, AH) or hascard(north, AH)
hasKingHearts  = hascard(south, KH) or hascard(north, KH)
hasQueenHearts = hascard(south, QH) or hascard(north, QH)
hasJackHearts  = hascard(south, JH) or hascard(north, JH)
hasTenHearts   = hascard(south, TH) or hascard(north, TH)

hasAceDiamonds   = hascard(south, AD) or hascard(north, AD)
hasKingDiamonds  = hascard(south, KD) or hascard(north, KD)
hasQueenDiamonds = hascard(south, QD) or hascard(north, QD)
hasJackDiamonds  = hascard(south, JD) or hascard(north, JD)
hasTenDiamonds   = hascard(south, TD) or hascard(north, TD)

hasAceClubs   = hascard(south, AC) or hascard(north, AC)
hasKingClubs  = hascard(south, KC) or hascard(north, KC)
hasQueenClubs = hascard(south, QC) or hascard(north, QC)
hasJackClubs  = hascard(south, JC) or hascard(north, JC)
hasTenClubs   = hascard(south, TC) or hascard(north, TC)

// ---- Per-suit consecutive top-honor chain (combined NS) ----
chainSpadesAfterJack  = hasTenSpades   ? 5 : 4
chainSpadesAfterQueen = hasJackSpades  ? chainSpadesAfterJack  : 3
chainSpadesAfterKing  = hasQueenSpades ? chainSpadesAfterQueen : 2
chainSpadesAfterAce   = hasKingSpades  ? chainSpadesAfterKing  : 1
chainSpades           = hasAceSpades   ? chainSpadesAfterAce   : 0

chainHeartsAfterJack  = hasTenHearts   ? 5 : 4
chainHeartsAfterQueen = hasJackHearts  ? chainHeartsAfterJack  : 3
chainHeartsAfterKing  = hasQueenHearts ? chainHeartsAfterQueen : 2
chainHeartsAfterAce   = hasKingHearts  ? chainHeartsAfterKing  : 1
chainHearts           = hasAceHearts   ? chainHeartsAfterAce   : 0

chainDiamondsAfterJack  = hasTenDiamonds   ? 5 : 4
chainDiamondsAfterQueen = hasJackDiamonds  ? chainDiamondsAfterJack  : 3
chainDiamondsAfterKing  = hasQueenDiamonds ? chainDiamondsAfterQueen : 2
chainDiamondsAfterAce   = hasKingDiamonds  ? chainDiamondsAfterKing  : 1
chainDiamonds           = hasAceDiamonds   ? chainDiamondsAfterAce   : 0

chainClubsAfterJack  = hasTenClubs   ? 5 : 4
chainClubsAfterQueen = hasJackClubs  ? chainClubsAfterJack  : 3
chainClubsAfterKing  = hasQueenClubs ? chainClubsAfterQueen : 2
chainClubsAfterAce   = hasKingClubs  ? chainClubsAfterKing  : 1
chainClubs           = hasAceClubs   ? chainClubsAfterAce   : 0

// ---- Longer single-hand length per suit ----
longerHandSpades   = spades(south)   > spades(north)   ? spades(south)   : spades(north)
longerHandHearts   = hearts(south)   > hearts(north)   ? hearts(south)   : hearts(north)
longerHandDiamonds = diamonds(south) > diamonds(north) ? diamonds(south) : diamonds(north)
longerHandClubs    = clubs(south)    > clubs(north)    ? clubs(south)    : clubs(north)

// ---- Per-suit top tricks = min(chain, longer hand) ----
topTricksSpades   = chainSpades   < longerHandSpades   ? chainSpades   : longerHandSpades
topTricksHearts   = chainHearts   < longerHandHearts   ? chainHearts   : longerHandHearts
topTricksDiamonds = chainDiamonds < longerHandDiamonds ? chainDiamonds : longerHandDiamonds
topTricksClubs    = chainClubs    < longerHandClubs    ? chainClubs    : longerHandClubs

// ---- Total (collapses to 0 if any suit unstopped) ----
allSuitsStopped = hasAceSpades and hasAceHearts and hasAceDiamonds and hasAceClubs
topTricksRaw    = topTricksSpades + topTricksHearts + topTricksDiamonds + topTricksClubs
topTricksNS     = allSuitsStopped ? topTricksRaw : 0
// Provides topTricksSpades, topTricksHearts, topTricksDiamonds, topTricksClubs, topTricksNS

### Imported Leveling Code ###
c1 = hascard(west,2C)
c2 = hascard(east,2D)
c3 = hascard(west,3C)
c4 = hascard(east,3D)

keep06 = c1 and c2          // this is used later w/c3 & c4 expressions
keep44 = c3 or c4           // this is used later w/c1 & c2 expressions

keep015 = keep06 and c3
keep03 = keep06 and keep44
keep045 = keep06 and not c3
####06 = c1 and c2
keep11 = c1 and keep44
keep14 = c1 and not keep44
keep19 = c1 and not c2
keep25 = c1
keep30 = keep06 or c3
keep33 = c1 or (c2 and keep44)
####44 = c3 or c4
keep47 = keep44 or keep06

keep53 = not keep47
keep56 = not keep44
keep67 = not keep33
keep70 = not keep30
keep75 = not keep25
keep81 = not keep19
keep86 = not keep14
keep89 = not keep11
keep94 = not keep06
keep955 = not keep045
keep97 = not keep03
keep985 = not keep015
keep   = 1
keep0  = 0
### End of Imported Leveling Code ###
// Provides keep015 (~1.5%), keep06 (~6%), keep (=1) — used to balance the
// pass / 2NT / 3NT cases against each other.

// ----- Opener (South) — 1NT, 15-17, balanced (Basic-Bridge shape) -----
sShape = shape(south, any 4333 + any 4432)
sHcp   = hcp(south) > 14 and hcp(south) < 18

// ----- Responder (North) — no 4-card major, no 6+ suit, no 5-5 -----
nNoMajor4 = spades(north) < 4 and hearts(north) < 4
nShape    = shape(north, xxxx -any 7xxx -any 6xxx -any 55xx)

// Quiet opponents
eHcp = hcp(east) < 11
wHcp = hcp(west) < 11

# Define responder's three action paths, with Leveling factors to balance
# the natural rates (Pass ~7.2%, 2NT ~2.2%, 3NT ~90.6%) toward roughly
# equal distribution. 2NT is the rarest path; reduce Pass and 3NT to match.
nPass = hcp(north)<9  and topTricksNS == 7                                           and keep30
n2N   = hcp(north)==9 and topTricksNS == 8                                           and keep
n3N   = hcp(north)>9  and hcp(north)<15 and topTricksNS >= 9 and topTricksNS <= 11   and keep03
nActs = nPass or n2N or n3N

// Ground-truth marker for the play trainer / grader: West's club spot
// cards encode the top-trick count without affecting bidding or play.
//   7C only (no 8C, no 9C) → exactly 7 top tricks  (Pass)
//   8C only (no 7C, no 9C) → exactly 8 top tricks  (2NT)
//   9C only (no 7C, no 8C) → 9+ top tricks         (3NT)
nsMarker = (topTricksNS == 7 and     hascard(west, 7C) and not hascard(west, 8C) and not hascard(west, 9C))
        or (topTricksNS == 8 and not hascard(west, 7C) and     hascard(west, 8C) and not hascard(west, 9C))
        or (topTricksNS >= 9 and not hascard(west, 7C) and not hascard(west, 8C) and     hascard(west, 9C))

// nActs encodes the three responder paths (Pass / 2NT / 3NT). Each path's
// topTricksNS check implicitly requires all 4 aces in NS in the 2NT and
// 3NT cases (see script/topTricksNS — it collapses to 0 if any suit is
// unstopped).
sShape and sHcp and nNoMajor4 and nShape and nActs and eHcp and wHcp and nsMarker

action printoneline,
average "North Pass    " 100 * nPass,
average "North 2NT     " 100 * n2N,
average "North 3NT     " 100 * n3N,
average "top tricks    "       topTricksNS,
average "South HCP     "       hcp(south),
average "North HCP     "       hcp(north),
`, "S", true)
Script
Button,Top Tricks (NT),\n\
--- Top Tricks — Notrump Contract (beginner)\n\
1NT — Pass — 3NT — all pass. Final contract is 3NT (declarer needs 9 tricks).\n\
\n\
Teaching feature: NS holds all 4 aces (in either hand) AND exactly 9 quick\n\
tricks on top. We assume outside entries exist，so split chains DO count\n\
(e.g.，AK opposite Qxx = 3 QT). The per-suit count is capped by the\n\
longer single-hand length in that suit (so AK opposite Qx = 2 QT，since\n\
no hand has 3 cards in the suit).\n\
\n\
Responder is constrained to no 4-card major (so no Stayman) and no 5-card\n\
major (so no transfer). The auction stays natural 1NT—3NT.\n\
\n\
Things to think about:\n\
• Count your top tricks before touching the hand.\n\
• Chain rule: A，then K (anywhere in NS)，then Q，then J，then T.\n\
• Length cap: split chains need length in the longer hand to materialize.\n\
\n\
Reference: https://www.bridgebum.com/counting.php\n\
%PlayTopTricksNT%
