Script,DOPIROPIPreempt
window.currentPBSScenario = 'DOPIROPIPreempt';
window.currentPBSScenarioFilename = 'DOPI_ROPI_vs_Preempt';
console.log('PBS: Logging scenario selection for DOPIROPIPreempt');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'DOPIROPIPreempt',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: 21GF-DEFAULT
convention-card-ew: 21GF-GIB
auction-filter: Auction.....\n[23][CDHS].+4N +[5X]
*/
# DOPI-ROPI vs Preempt: Interference over Blackwood after opponent preempts
dealer west

# West's weak 2: 6-card suit, 5-10 HCP, 2+ of top 5 honors
w2D = diamonds(west)==6 and top5(west,diamonds)>1 and hcp(west)>4 and hcp(west)<11
w2H = hearts(west)==6   and top5(west,hearts)>1   and hcp(west)>4 and hcp(west)<11
w2S = spades(west)==6   and top5(west,spades)>1   and hcp(west)>4 and hcp(west)<11
weak2 = w2D or w2H or w2S

# West's 3-level preempt: 7-card suit, 5-10 HCP, 2+ of top 5 honors
w3C = clubs(west)==7    and top5(west,clubs)>1    and hcp(west)>4 and hcp(west)<11
w3D = diamonds(west)==7 and top5(west,diamonds)>1 and hcp(west)>4 and hcp(west)<11
w3H = hearts(west)==7   and top5(west,hearts)>1   and hcp(west)>4 and hcp(west)<11
w3S = spades(west)==7   and top5(west,spades)>1   and hcp(west)>4 and hcp(west)<11
weak3 = w3C or w3D or w3H or w3S

wPreempt = weak2 or weak3

# N/S major fit — NOT in West's preempt suit
nH = hearts(north)>4 and hearts(south)>2 and not (w2H or w3H)
nS = spades(north)>4 and spades(south)>2 and not (w2S or w3S)
sH = hearts(south)>4 and hearts(north)>2 and not (w2H or w3H)
sS = spades(south)>4 and spades(north)>2 and not (w2S or w3S)
majorFit = nH or nS or sH or sS

# N/S slam zone
slamZone = hcp(north)>11 and hcp(south)>11 and (hcp(north)+hcp(south))>27

# East has 3+ fit for West's preempt suit (motivated to raise over 4NT)
eFitC = w3C             and clubs(east)>2
eFitD = (w2D or w3D)    and diamonds(east)>2
eFitH = (w2H or w3H)    and hearts(east)>2
eFitS = (w2S or w3S)    and spades(east)>2
eastFit = eFitC or eFitD or eFitH or eFitS

wPreempt and majorFit and slamZone and eastFit

produce 30

action printoneline,
average "hcp north    " hcp(north),
average "hcp south    " hcp(south),
average "hcp total    " (hcp(north)+hcp(south)),
average "hcp west     " hcp(west),
average "hcp east     " hcp(east)
`, "W", true)
Script
Button,DOPI-ROPI vs Preempt,\n\
--- DOPI-ROPI vs Preempt: After opponent opens a preempt\n\
Opponent opens a weak 2 or 3-level preempt.\n\
N/S find their major fit and bid Blackwood (4NT).\n\
East raises the preempt or doubles -> DOPI/ROPI applies.\n\
DOPI (opponent bids over 4NT):\n\
  D = Double = 0 keycards\n\
  O = next step up = 1 keycard\n\
  P = Pass = 1 keycard (without trump queen)\n\
  I = next steps = 2，3 keycards\n\
ROPI (opponent doubles 4NT):\n\
  R = Redouble = 0 keycards\n\
  O = next step up = 1 keycard\n\
  P = Pass = 1 keycard (without trump queen)\n\
  I = next steps = 2，3 keycards\n\
%DOPIROPIPreempt%
