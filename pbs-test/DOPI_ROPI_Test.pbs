Script,DOPIROPITest
window.currentPBSScenario = 'DOPIROPITest';
window.currentPBSScenarioFilename = 'DOPI_ROPI_Test';
console.log('PBS: Logging scenario selection for DOPIROPITest');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'DOPIROPITest',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: 21GF-DEFAULT
convention-card-ew: 21GF-DEFAULT
auction-filter: (4N +[X5]|4N\n[X5])
*/
# DOPI-ROPI Combined Test
dealer north

##### Imported Script -- GIB 1 Notrump #####

ntP = hcp(north) + shape(north,5xxx+x5xx)
nt1 = shape(north, any 5332+any 4432+any 4333) and hcp(north)>14 and ntP<18
nt2 = shape(north, any 5422-5xxx-x5xx-4xxx) and hcp(north)>14 and hcp(north)<17
gibNT = nt1 or nt2

### End of GIB 1 Notrump ###

# N/S slam zone (shared by both paths)
slamZone = hcp(south)>=12 and (hcp(north)+hcp(south))>=28

# === Path A: 3-level minor preempt by West, East supports ===
heartOpen = hearts(north)>4 and hearts(south)>3
spadeOpen = spades(north)>4 and spades(south)>3
majorFit = (heartOpen or spadeOpen) and not gibNT

wClubsLong    = clubs(west)>=7    and top4(west,clubs)>=3
wDiamondsLong = diamonds(west)>=7 and top4(west,diamonds)>=3
wMinor   = wClubsLong or wDiamondsLong
wRange   = hcp(west)>=8 and hcp(west)<=11
wShort   = (spadeOpen and spades(west)<=1) or (heartOpen and hearts(west)<=1)
eFit     = (wClubsLong and clubs(east)>=4) or (wDiamondsLong and diamonds(east)>=4)
eMin     = hcp(east)<10
preemptPath = majorFit and wMinor and wRange and wShort and eFit and eMin

# === Path B: 1-level overcall / Unusual NT with 11+ major fit ===
nOpens     = hcp(north)>=12 and hcp(north)<=21 and not gibNT
ewHearts11 = hearts(west)+hearts(east)>=11 and hearts(west)>=5 and hearts(east)>=5
ewSpades11 = spades(west)+spades(east)>=11 and spades(west)>=5 and spades(east)>=5
heartScn   = ewHearts11 and (clubs(north)>=5 or diamonds(north)>=5) and hearts(north)<5 and spades(north)<5
spadeScn   = ewSpades11 and (clubs(north)>=5 or diamonds(north)>=5 or hearts(north)>=5) and spades(north)<5
ewModest   = (hcp(west)+hcp(east))<=22
overcallPath = nOpens and (heartScn or spadeScn) and ewModest

# Combined: either path qualifies
slamZone and (preemptPath or overcallPath)

action printoneline,
average "hcp north       " hcp(north),
average "hcp south       " hcp(south),
average "hcp e+w         " (hcp(east)+hcp(west)),
average "preempt path %  " 100 * preemptPath,
average "overcall path % " 100 * overcallPath,
`, "N", true)
Script
Button,DOPI-ROPI Test (Combined),\n\
--- DOPI-ROPI Test (Combined: 3-level preempt + 1-level/Unusual NT)\n\
Two paths to DOPI/ROPI: (A) one opponent preempts a 7+ minor at 3-level\n\
with partner support; (B) E/W have an 11+ major fit and start with a\n\
1-level overcall or Unusual NT. Either way，N/S in slam zone reach 4NT\n\
and opponents compete to 5-level.\n\
%DOPIROPITest%,backgroundColor=lightpink
