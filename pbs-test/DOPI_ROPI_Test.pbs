Script,DOPIROPITest
window.currentPBSScenario = 'DOPIROPITest';
window.currentPBSScenarioFilename = 'DOPI_ROPI_Test';
console.log('PBS: Logging scenario selection for DOPIROPITest');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'DOPIROPITest',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: 21GF-DEFAULT
convention-card-ew: 21GF-DEFAULT
auction-filter: (4N +[X5]|4N\n[X5])
*/
# DOPI-ROPI Preemptive-Minor Test
dealer north

##### Imported Script -- GIB 1 Notrump #####

ntP = hcp(north) + shape(north,5xxx+x5xx)
nt1 = shape(north, any 5332+any 4432+any 4333) and hcp(north)>14 and ntP<18
nt2 = shape(north, any 5422-5xxx-x5xx-4xxx) and hcp(north)>14 and hcp(north)<17
gibNT = nt1 or nt2

### End of GIB 1 Notrump ###

# North opens 1 Major, South has 4+ support for Jacoby 2NT
heartOpen = hearts(north)>4 and hearts(south)>3
spadeOpen = spades(north)>4 and spades(south)>3
majorFit = (heartOpen or spadeOpen) and not gibNT

# N/S have slam-zone values
slamZone = hcp(north)>11 and hcp(south)>12 and (hcp(north)+hcp(south))>27

# Path A: West has the long minor, East supports & raises
wClubsLong    = clubs(west)>=7    and top4(west,clubs)>=3
wDiamondsLong = diamonds(west)>=7 and top4(west,diamonds)>=3
wMinor = wClubsLong or wDiamondsLong
wRange = hcp(west)>=8 and hcp(west)<=11
wShort = (spadeOpen and spades(west)<=1) or (heartOpen and hearts(west)<=1)
eSupport = (wClubsLong and clubs(east)>=4) or (wDiamondsLong and diamonds(east)>=4)
eShape   = spades(east)<4 and hearts(east)<4
eMin     = hcp(east)<10
westPath = wMinor and wRange and wShort and eSupport and eShape and eMin

# Path B: East has the long minor, West supports & raises (mirror)
eClubsLong    = clubs(east)>=7    and top4(east,clubs)>=3
eDiamondsLong = diamonds(east)>=7 and top4(east,diamonds)>=3
eMinor = eClubsLong or eDiamondsLong
eRange = hcp(east)>=8 and hcp(east)<=11
eShort = (spadeOpen and spades(east)<=1) or (heartOpen and hearts(east)<=1)
wSupport = (eClubsLong and clubs(west)>=4) or (eDiamondsLong and diamonds(west)>=4)
wShape   = spades(west)<4 and hearts(west)<4
wMin     = hcp(west)<10
eastPath = eMinor and eRange and eShort and wSupport and wShape and wMin

majorFit and slamZone and (westPath or eastPath)

action printoneline,
average "hcp north     " hcp(north),
average "hcp south     " hcp(south),
average "hcp total     " (hcp(north)+hcp(south)),
average "west long     " 100 * westPath,
average "east long     " 100 * eastPath,
`, "N", true)
Script
Button,DOPI-ROPI Test,\n\
--- DOPI-ROPI Test (Preemptive minor，either opponent，21GF-DEFAULT both sides)\n\
Diagnostic: One opponent holds 7+ in a minor with AKQJ; partner has 4+ support\n\
and no 4-card major. Should preempt and compete. After N/S reach 4NT，do\n\
opponents bid 5-level，triggering DOPI/ROPI from N/S?\n\
%DOPIROPITest%,backgroundColor=lightpink
