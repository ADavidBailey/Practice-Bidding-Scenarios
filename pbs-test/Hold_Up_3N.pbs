window.currentPBSScenario = 'HoldUp3N';
window.currentPBSScenarioFilename = 'Hold_Up_3N';
console.log('PBS: Logging scenario selection for HoldUp3N');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'HoldUp3N',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: Basic-Bridge
convention-card-ew: Basic-Bridge
auction-filter: Auction.....\n1N
*/
# curate: kind=avoidance oracle=holdup contract=3N seat=S
# convention-card-ns: Basic-Bridge
# convention-card-ew: Basic-Bridge


predeal south HA
predeal west  HKQ

dealer south

# South opens 1NT — balanced 15-17, exactly one heart stopper (the bare Ace)
sShape = shape(south, any 4333 + any 4432 + any 5332)
sHcp   = hcp(south) > 14 and hcp(south) < 18
sStop  = hearts(south) < 4
southHand = sShape and sHcp and sStop

# North 10-12 raises to 3NT
nHcp = hcp(north) > 9 and hcp(north) < 13
northHand = nHcp

# West (the opening leader) holds the long heart threat and NO outside entry
# (hcp < 8 with KQ = at most a stray jack outside — no side ace or king)
wHearts = hearts(west) > 4
wWeak   = hcp(west) < 8
westHand = wHearts and wWeak

# East is short in hearts so the hold-up exhausts the danger hand; being the
# stronger defender, East tends to hold the side-suit entry to knock out
eHearts = hearts(east) < 4
eastHand = eHearts

southHand and northHand and westHand and eastHand

action printoneline,
average "East heart length "       hearts(east),
average "West heart length "       hearts(west),
average "South HCP         "       hcp(south),
average "North HCP         "       hcp(north),
`, "S", true)
Script
Button,Hold-Up at 3NT,\n\
--- Hold-Up at 3NT (duck to sever the defenders' long suit)\n\
South opens 1NT (15-17 balanced)，North raises to 3NT.\n\
\n\
Teaching feature: declarer has exactly ONE stopper in hearts (the Ace).\n\
WEST — the opening leader — has a 5-card heart suit headed by KQ and leads\n\
it. East has only 2-3 hearts but holds the side-suit entry declarer must\n\
knock out.\n\
\n\
If declarer wins the first heart，then knocks out East's entry，East still\n\
has a heart to return and West cashes the long suit — 3NT goes down.\n\
\n\
The hold-up technique: refuse to win the early heart tricks. Duck until\n\
EAST (the hand with the entry) is OUT of hearts，then win the Ace. Now when\n\
declarer drives out East's entry，East has no heart to return — West's\n\
established hearts are stranded with no way back in.\n\
\n\
Things to think about:\n\
• How many times should you duck? Just enough to exhaust East's hearts.\n\
• After ducking，where will you take your remaining tricks?\n\
• Lose the lead only to East (safe once they are out of hearts); keep West,\n\
  with the long suit and no entry，off lead.\n\
\n\
Reference: https://www.bridgebum.com/hold-up_play.php\n\
%HoldUp3N%
