Script,ImpossibleNegative
window.currentPBSScenario = 'ImpossibleNegative';
window.currentPBSScenarioFilename = 'SCS_Impossible_Negative';
console.log('PBS: Logging scenario selection for ImpossibleNegative');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'ImpossibleNegative',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: Precision
convention-card-ew: 21GF-GIB
auction-filter: Auction.....\n1C +Pass +1D
*/
# South opens 1C (Precision: 15+ HCP)
hcp(south)>14

# North has Impossible Negative: any 4441, 8+ HCP
and hcp(north)>7 and shape(north, any 4441)

# Calm opponents
and hcp(east)<10 and hcp(west)<10
action printoneline,
`, "S", true)
Script
Button,Impossible Negative,\n\
--- Impossible Negative after 1!C opening\n\
After a Precision 1!C (15+ HCP)，responder bids 1!D with any 4441 hand and 8+ HCP.\n\
This "impossible" negative bid (looks like 0-7 HCP) allows responder to later reveal shape:\n\
  • Jump in singleton after opener's rebid (if opener hasn't bid it)\n\
  • Jump to NT if opener bids responder's singleton\n\
https://www.bridgebum.com/impossible_negative.php\n\
%ImpossibleNegative%,backgroundColor=lightpink
