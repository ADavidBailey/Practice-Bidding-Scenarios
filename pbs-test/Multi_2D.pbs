Script,Multi2D
window.currentPBSScenario = 'Multi2D';
window.currentPBSScenarioFilename = 'Multi_2D';
console.log('PBS: Logging scenario selection for Multi2D');
fetch('https://bba.harmonicsystems.com/api/scenario/select', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'X-Client-Version': '1.0.0'
    },
    body: JSON.stringify({
        scenario: 'Multi2D',
        user: whoAmI() || 'anonymous'
    })
}).then(function(r){ console.log('PBS: Server response', r.status); }).catch(function(e){ console.log('PBS: Fetch error', e); });
setDealerCode(`

/*
convention-card-ns: 21GF-Multi
convention-card-ew: 21GF-GIB
auction-filter: Auction.....\n2D
*/
# Multi 2D
dealer south

# Define South weak 2 bids
w2S = spades(south)==6 and top5(south,spades)>2 and hcp(south,spades)>4 and hearts(south)<4
w2H = hearts(south)==6 and top5(south,hearts)>2 and hcp(south,hearts)>4 and spades(south)<4

# Weak 2
weakTwo = hcp(south)>5 and hcp(south)<11 and (w2S or w2H)

# 17-24 HCP with 4441
four1 = hcp(south)>16 and hcp(south)<25 and shape(south, any 4441)

# 20-21 NT hand for Lars
twoNT = hcp(south)>19 and hcp(south)<22 and shape(south, any 4333 +any 4432 +any 5332)

// weakTwo and twoNT

weakTwo and four1
action printoneline,
`, "S", true)
Script
Button,Multi 2D,\n\
--- Multi 2!D\n\
A Multi 2!D bid shows either a weak two in !H or !S or a 17-24 HCP 4441 hand.\n\
See Bridge Bum's Multi 2!D:\n\
https://www.bridgebum.com/multi_2d.php\n\
%Multi2D%,backgroundColor=lightpink
