# alias: test
# button-text: Test
# gib-works: true
# bba-works: true
# auction-filter: ^(5.|.* .* 5.) =.=
# convention-card-ns: 21GF-GIB
# convention-card-ew: 21GF-GIB

/*@chat
--- Test: 1D-P-1H-2S, P-4S-4N
@chat*/

dealer south

#include "script/TP"

# South opens 1D: 12-14 TP, 4+ diamonds, no 5-card major
sD = diamonds(south)>3 and diamonds(south)>=clubs(south)
sNoMajor = spades(south)<5 and hearts(south)<5
sNT = hcp(south)>14 and hcp(south)<17 and shape(south,any 5332 +any 4432 +any 4333 -5xxx -x5xx)
sOpens1D = sD and sNoMajor and not sNT and hcp(south)>11 and hcp(south)<15

# North responds 1H then bids 4N (Unusual NT): 4+ H, 5+ D, 5+ C, 18+ TP
# Shape: 0-4-5-4, 0-4-4-5, 0-5-4-4, 0-5-5-3, 0-4-5-4, etc.
nShape = shape(north,0445 +0454)
nTens = hascard(north,TH) + hascard(north,TD) + hascard(north,TC)
nNines = hascard(north,9H) + hascard(north,9D) + hascard(north,9C)
nResp = nShape and tpNorth>15 and (nTens + nNines)>2

# West passes over 1D: not enough to act
wPasses = hcp(west)<15

# East overcalls 2S: 6+ spades pushes BBA to jump to 2S not 1S
eOvercall = spades(east)>5 and hcp(east)<10 and tpEast>2

# West raises to 4S: 4+ spades, poor quality if 5+ (at most Q high), 16- TP
wRaise = spades(west)>3 and (spades(west)==4 or hcp(west,spades)<3) and tpWest<17
sOpens1D and nResp and wPasses and eOvercall and wRaise

produce 40
action
printoneline,
